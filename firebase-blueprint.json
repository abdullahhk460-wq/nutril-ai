{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user preferences, budget, and health goals.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "country": { "type": "string" },
        "province": { "type": "string" },
        "dailyBudget": { "type": "number" },
        "weeklyBudget": { "type": "number" },
        "monthlyBudget": { "type": "number" },
        "healthGoal": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "country", "dailyBudget", "healthGoal"]
    },
    "MealItem": {
      "title": "Default Food Item",
      "description": "User-defined default food items for different meal times.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["breakfast", "lunch", "dinner", "optional"] },
        "quantity": { "type": "string" }
      },
      "required": ["userId", "name", "price", "category"]
    },
    "Expense": {
      "title": "Meal Expense",
      "description": "Record of money spent on a specific meal.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string", "enum": ["breakfast", "lunch", "dinner", "other"] },
        "date": { "type": "string", "format": "date-time" },
        "note": { "type": "string" }
      },
      "required": ["userId", "amount", "category", "date"]
    },
    "AIPlan": {
      "title": "AI Generated Plan",
      "description": "Stores plans generated by Gemini AI for the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "plan": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "goal": { "type": "string" }
      },
      "required": ["userId", "plan", "createdAt"]
    },
    "ScheduledNotification": {
      "title": "Scheduled Notification",
      "description": "Stores a user's scheduled push notification.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "sent", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "scheduledAt", "status"]
    },
    "UserSubscription": {
      "title": "Push Subscription",
      "description": "Stores browser push subscription for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subscription": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "subscription"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles."
    },
    "/users/{userId}/meals/{mealId}": {
      "schema": "MealItem",
      "description": "Default meal items for a user."
    },
    "/users/{userId}/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Logged expenses for a user."
    },
    "/users/{userId}/ai_plans/{planId}": {
      "schema": "AIPlan",
      "description": "History of AI suggested plans."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "ScheduledNotification",
      "description": "User's notification schedule and history."
    },
    "/subscriptions/{subId}": {
      "schema": "UserSubscription",
      "description": "User browser push tokens."
    }
  }
}
